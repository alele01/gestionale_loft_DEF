# ============================================================================
# Cooker Loft V1 — Environment variables
# ----------------------------------------------------------------------------
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and never committed.
# See docs/SECURITY.md §8 for the full secrets inventory.
# ============================================================================

# ----------------------------------------------------------------------------
# Server-only (NEVER expose to the browser)
# These are read exclusively from server code (route handlers, server actions,
# scripts) via src/server/env.ts. They MUST NOT be referenced by client code
# and MUST NOT have the NEXT_PUBLIC_ prefix.
# ----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Absolute base URL used by server code (e.g. building completion links).
APP_BASE_URL=http://localhost:3000

# Fallback accountant email used only if app_settings.accountant_email is empty.
ACCOUNTANT_FALLBACK_EMAIL=

# Contact email shown on /complete/[token] when the representative needs to
# correct read-only data. Falls back to ACCOUNTANT_FALLBACK_EMAIL if empty.
VENUE_CONTACT_EMAIL=

# ----------------------------------------------------------------------------
# Resend (transactional email) — required for E1..E5, E8, E9.
# Create the API key at https://resend.com/api-keys (must start with `re_`).
# The sender domain must be verified in Resend (DKIM/SPF/DMARC). See
# docs/EMAILS.md §1 for the deliverability checklist.
# ----------------------------------------------------------------------------
RESEND_API_KEY=
# Format: `Cooker Loft <noreply@mail.cookerloft.example>`
RESEND_FROM_EMAIL=
# Optional. Falls back to VENUE_CONTACT_EMAIL when empty.
RESEND_REPLY_TO_EMAIL=

# ----------------------------------------------------------------------------
# Vercel Cron — shared secret enforced by /api/cron/review.
# In Vercel project settings, configure CRON_SECRET; Vercel Cron will send
# `Authorization: Bearer ${CRON_SECRET}` automatically.
# In local dev you can leave it empty (the endpoint will accept any request).
# ----------------------------------------------------------------------------
CRON_SECRET=

# ----------------------------------------------------------------------------
# Stripe Checkout + webhook (Phase 5)
# ----------------------------------------------------------------------------
# Get the secret key from https://dashboard.stripe.com/test/apikeys
# (sk_test_... in sandbox, sk_live_... in production — set live keys
# only in Vercel project settings, never in .env.local).
STRIPE_SECRET_KEY=
# In local development, run:
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
# Then copy the printed `whsec_...` ephemeral secret here. In production,
# use the permanent webhook secret from
# https://dashboard.stripe.com/test/webhooks (or live equivalent).
STRIPE_WEBHOOK_SECRET=
